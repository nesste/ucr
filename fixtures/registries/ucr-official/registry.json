      "inputs": [
        {
          "name": "entity",
          "type": "string",
          "description": "Entity name, for example Post."
        },
        {
          "name": "plural",
          "type": "string",
          "description": "Plural route segment, for example posts."
        },
        {
          "name": "fields",
          "type": "json",
          "description": "Field metadata used to render entity code."
        }
      ],
      "provides": ["entity-contract:{{instanceId}}"],
      "outputs": [
        {
          "template": "templates/entity-contract/contract/model.ts.tpl",
          "target": "model.ts",
          "surface": "contract"
        }
      ]
    },
