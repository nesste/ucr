{
  "$schema": "../../../packages/schema/registry.schema.json",
  "name": "ucr-official",
  "version": "3.0.0",
  "items": [
    {
      "name": "ts-runtime",
      "kind": "utility",
      "version": "1.0.0",
      "category": "typescript",
      "description": "Typed composition runtime for utility-first TypeScript blocks.",
      "targets": ["shared"],
      "provides": ["runtime:ts"],
      "metadata": {
        "exports": "defineUtility,definePreset,compose"
      },
      "outputs": [
        {
          "template": "templates/ts-runtime/utility/index.ts.tpl",
          "target": "index.ts",
          "surface": "utility"
        }
      ]
    },
    {
      "name": "result-utility",
      "kind": "utility",
      "version": "1.0.0",
      "category": "typescript",
      "description": "Small result helpers for predictable service and transport flows.",
      "targets": ["shared"],
      "requires": ["runtime:ts"],
      "provides": ["utility:result-utility"],
      "metadata": {
        "exports": "ok,err,mapResult,mapError,matchResult"
      },
      "outputs": [
        {
          "template": "templates/result-utility/utility/result-utility.ts.tpl",
          "target": "result-utility.ts",
          "surface": "utility"
        }
      ]
    },
    {
