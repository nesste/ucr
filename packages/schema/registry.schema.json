{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucr.local/registry.schema.json",
  "title": "Universal Code Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "version", "items"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "distribution": {
      "$ref": "#/$defs/distribution"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/item"
      }
    }
  },
  "$defs": {
    "distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "bundleUrl", "checksum"],
      "properties": {
        "format": {
          "const": "zip"
        },
        "bundleUrl": {
          "type": "string",
          "minLength": 1
        },
        "checksum": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": ["string", "number", "boolean", "json"]
        },
        "description": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["template", "target", "surface"],
      "properties": {
        "template": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "surface": {
          "enum": [
            "contract",
            "domain",
            "transport",
            "ui",
            "test",
            "config",
            "entrypoint",
            "utility",
            "preset"
          ]
        },
        "description": {
          "type": "string"
        },
        "overwrite": {
          "type": "boolean"
        }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "version",
        "category",
        "targets",
        "outputs"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "enum": ["block", "utility", "preset"]
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["shared", "next-app-router", "bun-http"]
          },
          "uniqueItems": true
        },
        "requires": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "provides": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "compose": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "entrypoints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/input"
          }
        },
        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/output"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "preset"
              }
            }
          },
          "then": {
            "required": ["compose"],
            "properties": {
              "compose": {
                "minItems": 1
              }
            }
          },
          "else": {
            "not": {
              "required": ["compose"]
            }
          }
        }
      ]
    }
  }
}
