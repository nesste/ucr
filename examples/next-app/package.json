{
  "name": "@ucr/example-next-app",
  "private": true,
  "version": "0.0.0",
  "packageManager": "bun@1.3.4",
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "build": "next build",
    "clean": "node -e \"require('node:fs').rmSync('.next', { recursive: true, force: true })\"",
    "dev": "next dev",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "registry:init": "bun ../../packages/cli/dist/bin.js init --registry ../../fixtures/registries/ucr-official/registry.json --target .",
    "registry:list": "bun ../../packages/cli/dist/bin.js list --target .",
    "registry:show": "bun ../../packages/cli/dist/bin.js show admin-page --target ."
  }
}
